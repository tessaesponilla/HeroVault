<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🩺 Health &amp; Persona Discovery"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/deep_blue"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="This psychological assessment will identify the Health Companion best suited for your current life path."
            android:textSize="14sp"
            android:textColor="#666"
            android:gravity="center"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="32dp" />

        <!-- User Name Input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilUserName"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:hint="Enter Your Name">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etUserName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPersonName" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 1. Physical Energy -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="1. How often do you feel physically capable of handling demanding tasks?" android:textStyle="bold" android:layout_marginBottom="8dp" />
                <RadioGroup android:id="@+id/rgPhyEnergy" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <RadioButton android:id="@+id/rbPhyE1" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Always ready and energetic" />
                    <RadioButton android:id="@+id/rbPhyE2" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Sometimes struggle with fatigue" />
                    <RadioButton android:id="@+id/rbPhyE3" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Often feel weak or stagnant" />
                </RadioGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 2. Mental Focus -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="2. How do you handle a massive influx of information or tasks?" android:textStyle="bold" android:layout_marginBottom="8dp" />
                <RadioGroup android:id="@+id/rgMenFocus" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <RadioButton android:id="@+id/rbMenF1" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="I organize and prioritize immediately" />
                    <RadioButton android:id="@+id/rbMenF2" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="I feel slightly pressured but manage" />
                    <RadioButton android:id="@+id/rbMenF3" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="I shut down and feel overwhelmed" />
                </RadioGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 3. Emotional Response -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="3. Do you find it easy to identify and regulate what you are feeling?" android:textStyle="bold" android:layout_marginBottom="8dp" />
                <RadioGroup android:id="@+id/rgEmoResp" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <RadioButton android:id="@+id/rbEmoR1" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Yes, I am very self-aware" />
                    <RadioButton android:id="@+id/rbEmoR2" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Usually, after some reflection" />
                    <RadioButton android:id="@+id/rbEmoR3" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="I am often confused by my moods" />
                </RadioGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 4. Social Connection -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="4. How much do you value connecting with others during stress?" android:textStyle="bold" android:layout_marginBottom="8dp" />
                <RadioGroup android:id="@+id/rgSocial" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <RadioButton android:id="@+id/rbSoc1" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Connection is vital to my healing" />
                    <RadioButton android:id="@+id/rbSoc2" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="I talk to others occasionally" />
                    <RadioButton android:id="@+id/rbSoc3" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="I prefer to isolate myself" />
                </RadioGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 5. Sleep Quality -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="5. How would you rate your sleep quality over the last week?" android:textStyle="bold" android:layout_marginBottom="8dp" />
                <RadioGroup android:id="@+id/rgSleep" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <RadioButton android:id="@+id/rbSlp1" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Deep and restorative" />
                    <RadioButton android:id="@+id/rbSlp2" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Restless or inconsistent" />
                    <RadioButton android:id="@+id/rbSlp3" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="I rarely get enough sleep" />
                </RadioGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 6. Motivation -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="6. Do you find it difficult to start new habits or projects?" android:textStyle="bold" android:layout_marginBottom="8dp" />
                <RadioGroup android:id="@+id/rgMotivation" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <RadioButton android:id="@+id/rbMot1" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="I am highly motivated" />
                    <RadioButton android:id="@+id/rbMot2" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="I need a nudge to start" />
                    <RadioButton android:id="@+id/rbMot3" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="I struggle with procrastination" />
                </RadioGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 7. Physical Activity -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="7. Do you prioritize physical movement in your daily routine?" android:textStyle="bold" android:layout_marginBottom="8dp" />
                <RadioGroup android:id="@+id/rgActivity" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <RadioButton android:id="@+id/rbAct1" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="It is my top priority" />
                    <RadioButton android:id="@+id/rbAct2" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="I do it when I have time" />
                    <RadioButton android:id="@+id/rbAct3" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="I rarely find the energy" />
                </RadioGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 8. Stress Management -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="8. How would you rate your ability to manage stress?" android:textStyle="bold" android:layout_marginBottom="8dp" />
                <RadioGroup android:id="@+id/rgStress" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <RadioButton android:id="@+id/rbStr1" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="I am calm under pressure" />
                    <RadioButton android:id="@+id/rbStr2" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="I manage with some effort" />
                    <RadioButton android:id="@+id/rbStr3" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="I easily feel overwhelmed" />
                </RadioGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 9. Routine Structure -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="9. Do you feel your life has a productive structure or routine?" android:textStyle="bold" android:layout_marginBottom="8dp" />
                <RadioGroup android:id="@+id/rgRoutine" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <RadioButton android:id="@+id/rbRou1" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="I have a solid routine" />
                    <RadioButton android:id="@+id/rbRou2" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="My routine is flexible" />
                    <RadioButton android:id="@+id/rbRou3" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="My days feel chaotic" />
                </RadioGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 10. Self-Care Priority -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            app:cardCornerRadius="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="10. How often do you put your own well-being before others?" android:textStyle="bold" android:layout_marginBottom="8dp" />
                <RadioGroup android:id="@+id/rgSelfCare" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <RadioButton android:id="@+id/rbCar1" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="I prioritize myself first" />
                    <RadioButton android:id="@+id/rbCar2" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="I try to find a balance" />
                    <RadioButton android:id="@+id/rbCar3" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="I always put others first" />
                </RadioGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <Button
            android:id="@+id/btnDiscover"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="Finalize Assessment"
            android:textSize="18sp"
            app:cornerRadius="32dp"
            android:layout_marginBottom="48dp" />

    </LinearLayout>
</ScrollView>